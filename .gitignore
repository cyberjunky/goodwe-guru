# ── Downloaded inverter firmware (proprietary GoodWe binaries -- never publish) ──
/updates/

# ── Android APK / decompiled files (not part of the app) ─────────────────────
*.apk
*.xapk
apk_assets/
apk_extracted/
android/extracted/
android/extracted_*/
android/decompiled/
android/decompiled_*/

# ── Frontend build artifacts ──────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/

# ── Root-level dev tooling (not needed in repo) ───────────────────────────────
# NOTE: anchor these to the repo root with a leading slash, otherwise they also
# ignore frontend/package.json — which broke every install (no manifest to build).
node_modules/
take-screenshots.js
spa-server.js
/package.json
/package-lock.json

# ── Python ────────────────────────────────────────────────────────────────────
backend/__pycache__/
backend/*.pyc
backend/.venv/
**/__pycache__/
**/*.pyc

# ── Runtime data (generated on the server) ────────────────────────────────────
/data/
*.db
*.db-shm
*.db-wal
forecast_cache.json

# ── Local secrets ─────────────────────────────────────────────────────────────
config.env
*.env
*.env.local

# ── Editors & OS ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/settings.json
*.swp
*.swo
